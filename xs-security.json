{
  "xsappname": "incident-list",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.read",
      "description": "With this scope, USER can read incidents."
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "Role to get the list of incidents",
      "scope-references": [
        "$XSAPPNAME.read"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "IncidentListViewer",
      "description": "Incident List Viewer",
      "role-template-references": [
        "$XSAPPNAME.Viewer"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/**"
    ]
  }
}